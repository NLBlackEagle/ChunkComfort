debug.chunkcomfort.group_breakdown=Group Breakdown: [Total Comfort: %1$s/%2$s]

# Explains debug output formatting
debug.chunkcomfort.group_breakdown_syntax=Syntax: Group, Points, Limit | Entity, Count, Limit


