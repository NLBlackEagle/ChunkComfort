# ============================================================
# Core Effect Name
# ============================================================

# Name of the Comfort status effect shown in the inventory/effects UI
chunkcomfort.effects.comfort=Comfort


# ============================================================
# Headers and General Tooltips
# ============================================================

# Main header shown at the top of Comfort-related tooltips
tooltip.chunkcomfort.header=§eComfort Info:

# Tooltip shown for blocks counted as valid comfort fire sources
# (campfires, fireplaces, etc.)
tooltip.chunkcomfort.fireblocks=§6A comfy fire, key to establishing a warm, lit and sheltered comfort zone.

# Tooltip for items capable of creating a valid comfort fire
# (flint & steel, fire charges, etc.)
tooltip.chunkcomfort.firestarters=§6Used to create a comfy fire establishing a warm, lit and sheltered comfort zone.

tooltip.chunkcomfort.inactive=Your surroundings don't feel very comfortable yet.

tooltip.chunkcomfort.blacklisted=A feeling of dread surrounds you, this place oozes tension.

tooltip.chunkcomfort.positive.effects=§2Comfort Effects:
tooltip.chunkcomfort.positive.effects.plus=§a+
tooltip.chunkcomfort.negative.effects=§4Negated Effects:
tooltip.chunkcomfort.positive.effects.minus=§c-

# ============================================================
# Decorative Entity Tooltips (paintings, item frames, etc.)
# ============================================================

# Shows total comfort points contributed by this decorative entity
# %1$s = entity points added
# %2$s/%3$s = current group total / group limit
tooltip.chunkcomfort.decorative.line1=§aEntity points: %1$s  Limit: %2$s/%3$s

# Displays which decorative group the entity belongs to
# %1$s = group name
# %2$s/%3$s = points in group / max allowed points
tooltip.chunkcomfort.decorative.line2=§bGroup: %1$s  Points: %2$s/%3$s


# ============================================================
# Comfort Block Tooltips
# ============================================================

# Displays comfort value contributed by a placed block
# %1$s = block points added
# %2$s/%3$s = current group total / group limit
tooltip.chunkcomfort.block.line1=§aBlock points: %1$s  Limit: %2$s/%3$s

# Shows block comfort group information
tooltip.chunkcomfort.block.line2=§bGroup: %1$s  Points: %2$s/%3$s


# ============================================================
# Living Entity Tooltips
# ============================================================

# Comfort contribution from living entities (pets, villagers, animals)
tooltip.chunkcomfort.living.line1=§aEntity points: %1$s  Limit: %2$s/%3$s

# Living entity group breakdown
tooltip.chunkcomfort.living.line2=§bGroup: %1$s  Points: %2$s/%3$s

# Bonus comfort granted when entities are named
# %1$s = list of names detected
# %2$s = bonus points awarded
tooltip.chunkcomfort.named_pets=Names: %1$s + %2$s points


# ============================================================
# Petting System
# ============================================================

# Instruction shown when looking at a pettable entity
tooltip.chunkcomfort.pet=§d§oShift + Left Click to pet your pet!

# Chat message shown when petting succeeds
# %1$s = entity name
tooltip.chunkcomfort.petting.message.line1=§6Petting your pet %1$s comforts you.

# Displays temporary comfort bonus
# %1$s = comfort gained
# %2$s = duration in seconds
tooltip.chunkcomfort.petting.message.line2=§6Comfort increased by %1$s point(s) for %2$s seconds!

# Cooldown Message for when your pet does not want to be petted just yet
# %1$s = seconds cooldown remaining
chunkcomfort.petting.cooldown=§6Your pet doesn't feel like being petted. Wait %1$s second(s).


# ============================================================
# Command Debug Messages
# ============================================================

# Usage hint for /chunkcomfort command
debug.chunkcomfort.usage=§cUsage: /chunkcomfort <info|reload|biome>

# Unknown subcommand warning
debug.chunkcomfort.unknown_subcommand=§cUnknown subcommand.


# ============================================================
# Reload Process Debug Messages
# ============================================================

# Reload process started (clears caches + reloads configs)
debug.chunkcomfort.reload_start=§a[ChunkComfort] Clearing caches and reloading...

# Config file successfully reloaded
debug.chunkcomfort.reload_config=§a[ChunkComfort] Config reloaded.

# Per-world cache cleared
# %1$s = world/dimension id
debug.chunkcomfort.reload_world=§a[ChunkComfort] Cleared caches for world: %1$s

# Comfort recalculation finished for all players
debug.chunkcomfort.reload_complete=§a[ChunkComfort] Comfort recalculated for all players.


# ============================================================
# System State Debugging
# ============================================================

# Printed when comfort system is disabled or inactive
# %1$s = reason
debug.chunkcomfort.inactive=Comfort system inactive: %1$s


